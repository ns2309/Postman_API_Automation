  "item": [
    {
      "name": "AddBook",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//NS12345\r",
              "const code =pm.globals.get(\"CompanyCode\");\r",
              "const val = pm.variables.replaceIn('{{$randomInt}}');\r",
              "\r",
              "\r",
              "pm.collectionVariables.set(\"isbn\",code + val);\r",
              "pm.collectionVariables.set(\"author_name\", pm.iterationData.get(\"Author\"));\r",
              "pm.collectionVariables.set(\"book_name\", pm.iterationData.get(\"BookName\"));\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Assertions validations- response\r",
              "const jsonData =pm.response.json();\r",
              "const book_Id = jsonData.ID;\r",
              "var req = JSON.parse(pm.request.body.raw);\r",
              "pm.environment.set(\"book_id\", book_Id);\r",
              "\r",
              "\r",
              "function cleanupScript()\r",
              "{\r",
              "    const book_Id =  generateBookId();\r",
              "    pm.environment.set(\"book_id\", book_Id);\r",
              "\r",
              "    pm.execution.setNextRequest(\"DeleteBook\");\r",
              "}\r",
              "\r",
              "function generateBookId()\r",
              "\r",
              "{\r",
              "  const expected_id = req.isbn + req.aisle;\r",
              "  return expected_id;\r",
              "}\r",
              "\r",
              "pm.test(\"Validate status code is 200\", function () \r",
              "{\r",
              "    try\r",
              "    {\r",
              "      pm.response.to.have.status(200);\r",
              "      pm.expect(jsonData).have.property(\"Msg\");\r",
              "      pm.expect(jsonData.Msg).to.eql(\"successfully added\");\r",
              "    \r",
              "    }\r",
              "    \r",
              "    catch (err)\r",
              "    {\r",
              "           if (jsonData.Msg.includes(\"Book Already Exists\"))\r",
              "           {\r",
              "              cleanupScript();\r",
              "           }\r",
              "\r",
              "    }\r",
              "    \r",
              "\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Headers cookies responsetime validation\", function()\r",
              "{\r",
              "    const ct = pm.response.headers.get(\"Content-Type\");\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "     pm.expect(ct).to.eql(\"application/json;charset=UTF-8\");\r",
              "    \r",
              "    pm.expect(pm.response.responseTime).to.be.below(2500);\r",
              "    pm.expect(\r",
              "    pm.response.text().includes(\"successfully added\") ||\r",
              "    pm.response.text().includes(\"Book Already Exists\")\r",
              ").to.be.true;\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\"ID Logic validation\", function()\r",
              "{\r",
              "  \r",
              "  const isbn_val = pm.collectionVariables.get(\"isbn\");\r",
              "  var req = JSON.parse(pm.request.body.raw);\r",
              "  const aisle_val = req.aisle;\r",
              "  const expected_id = isbn_val + aisle_val;\r",
              "\r",
              "  pm.expect(expected_id).to.eql(book_Id);\r",
              "  \r",
              "\r",
              "\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n\r\n\"name\":\"{{author_name}}\",\r\n\"isbn\":\"{{isbn}}\",\r\n\"aisle\":\"227\",\r\n\"author\":\"{{book_name}}\"\r\n} \r\n ",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/Library/Addbook.php",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Library",
            "Addbook.php"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GetBook",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const GetBook_Response = pm.response.json();\r",
              "\r",
              "const schema ={\r",
              "  \"type\": \"array\",\r",
              "  \"items\": [\r",
              "    {\r",
              "      \"type\": \"object\",\r",
              "      \"properties\": {\r",
              "        \"book_name\": {\r",
              "          \"type\": \"string\"\r",
              "        },\r",
              "        \"isbn\": {\r",
              "          \"type\": \"string\"\r",
              "        },\r",
              "        \"aisle\": {\r",
              "          \"type\": \"string\"\r",
              "        },\r",
              "        \"author\": {\r",
              "          \"type\": \"string\"\r",
              "        }\r",
              "      },\r",
              "      \"required\": [\r",
              "        \"book_name\",\r",
              "        \"isbn\",\r",
              "        \"aisle\",\r",
              "        \"author\"\r",
              "      ]\r",
              "    }\r",
              "  ]\r",
              "}\r",
              "\r",
              "\r",
              "pm.test(\"Validate the Json response logic\" ,function()\r",
              " {\r",
              "  console.log(GetBook_Response); \r",
              "\r",
              "  pm.expect(GetBook_Response[0].author).to.eql(pm.collectionVariables.get(\"author_name\"));\r",
              "  pm.expect(GetBook_Response[0].isbn).to.eql(pm.collectionVariables.get(\"isbn\"));\r",
              "\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Validate the Json response Schema\" ,function()\r",
              " {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "\r",
              "\r",
              "\r",
              "\r",
              " });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
